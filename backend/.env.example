PORT=5000
NODE_ENV=production

# Admin
ADMIN_EMAIL=your_email@example.com

# MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-content-saas

# Redis — Upstash (ioredis URL)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_here
JWT_EXPIRES_IN=7d

# AI (groq = miễn phí)
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key

# Frontend URL (Vercel URL)
FRONTEND_URL=https://your-app.vercel.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Free plan
FREE_CREDITS=10

# Ngân hàng
BANK_NAME=Vietcombank
BANK_ID=VCB
BANK_ACCOUNT_NUMBER=0201000686388
BANK_ACCOUNT_NAME=VO DUY HA
PRO_PRICE_VND=199000
PRO_DAYS=30
